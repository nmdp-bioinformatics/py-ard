"""
Generate hla_nom_m.txt — WMDA-format M (mature protein) grouping file.

M groups collect alleles whose mature protein sequences (IMGT positions >= 1)
are identical. The format mirrors hla_nom_g.txt:

    # file: hla_nom_m.txt
    # date: YYYY-MM-DD
    # ...5 more header lines...
    DPB1*;04:01:01:01/126:01;04:01:01M
    DPB1*;02:01:02:01;

Alleles with no sequence in HLAtools, or whose sequence contains '*'
(unsequenced positions), appear as singletons with an empty third field.

Usage:
    generate-m-nom
    generate-m-nom -o path/to/hla_nom_m.txt
    generate-m-nom -o hla_nom_m.txt --loci DPB1,DQB1
"""
import argparse
import datetime
import sys
from collections import defaultdict

from pyard.alignment_bridge import HLAToolsBridge, VALID_LOCI
from pyard.misc import get_M_name


def generate_m_groups(bridge, loci):
    """Group alleles in each locus by identical mature protein sequence.

    Args:
        bridge: Initialised HLAToolsBridge.
        loci: List of locus names to process.

    Returns:
        Dict mapping locus name to list of groups, where each group is a
        sorted list of full allele names. Single-allele groups represent
        singletons (no sequence, '*' in sequence, or unique sequence).
    """
    result = {}
    for locus in loci:
        print(f"  Loading alignment for {locus}...", flush=True)
        alignment = bridge.get_mature_alignment(locus)
        if not alignment:
            print(f"  Warning: no alignment data for {locus}, skipping.")
            continue

        # Group alleles by mature sequence.
        seq_to_alleles = defaultdict(list)
        singletons = []
        for allele, seq in sorted(alignment.items()):
            if not seq or "*" in seq:
                singletons.append([allele])
            else:
                seq_to_alleles[seq].append(allele)

        # Sort alleles within each group so output is deterministic.
        groups = [sorted(g) for g in seq_to_alleles.values()]
        groups.sort(key=lambda g: g[0])

        # Singletons are already individual lists; sort them by allele name too.
        singletons.sort(key=lambda g: g[0])

        result[locus] = groups + singletons

    return result


def write_m_nom_file(m_groups, loci, output_path):
    """Write M groups to a WMDA-format text file.

    Args:
        m_groups: Output of generate_m_groups().
        loci: Ordered list of loci (controls output order).
        output_path: Destination file path.
    """
    today = datetime.date.today().isoformat()
    header = [
        "# file: hla_nom_m.txt",
        f"# date: {today}",
        "# version: generated from HLAtools protein alignment data",
        "# origin: generated by py-ard generate-m-nom script",
        "# repository: https://github.com/nmdp-bioinformatics/py-ard",
        "# author: py-ard project (NMDP/CIBMTR)",
    ]

    lines = list(header)
    for locus in loci:
        if locus not in m_groups:
            continue
        locus_prefix = f"{locus}*"
        for group in m_groups[locus]:
            # Strip the locus prefix from each allele for the compact format.
            short_alleles = [a.split("*", 1)[1] for a in group]
            allele_str = "/".join(short_alleles)
            if len(group) > 1:
                m_name = get_M_name(group[0]).split("*", 1)[1]
                lines.append(f"{locus_prefix};{allele_str};{m_name}")
            else:
                lines.append(f"{locus_prefix};{allele_str};")

    with open(output_path, "w") as f:
        f.write("\n".join(lines) + "\n")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Generate hla_nom_m.txt: WMDA-format M (mature protein) grouping file."
    )
    parser.add_argument(
        "-o",
        "--output",
        dest="output",
        default="hla_nom_m.txt",
        help="Output file path (default: hla_nom_m.txt)",
    )
    parser.add_argument(
        "--loci",
        dest="loci",
        help=(
            "Comma-separated loci to include "
            f"(default: all {len(VALID_LOCI)} standard loci)"
        ),
    )
    args = parser.parse_args()

    if args.loci:
        loci = [l.strip() for l in args.loci.split(",")]
        invalid = [l for l in loci if l not in VALID_LOCI]
        if invalid:
            print(f"Error: invalid loci: {invalid}", file=sys.stderr)
            print(f"Valid loci: {VALID_LOCI}", file=sys.stderr)
            sys.exit(1)
    else:
        loci = list(VALID_LOCI)

    bridge = HLAToolsBridge(loci=loci)
    if not bridge.is_available:
        print(
            "Error: rpy2 and the HLAtools R package are required.\n"
            "  pip install rpy2\n"
            "  Rscript -e \"install.packages('HLAtools')\"",
            file=sys.stderr,
        )
        sys.exit(1)

    print(f"Generating M groups for loci: {loci}")
    m_groups = generate_m_groups(bridge, loci)

    total_groups = sum(
        sum(1 for g in groups if len(g) > 1) for groups in m_groups.values()
    )
    total_alleles_collapsed = sum(
        sum(len(g) for g in groups if len(g) > 1) for groups in m_groups.values()
    )
    print(f"Found {total_groups} M groups covering {total_alleles_collapsed} alleles.")

    print(f"Writing {args.output}...")
    write_m_nom_file(m_groups, loci, args.output)
    print("Done.")
